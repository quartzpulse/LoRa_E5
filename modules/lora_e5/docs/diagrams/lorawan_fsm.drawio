<mxfile host="app.diagrams.net" modified="2026-07-01T00:00:00.000Z" agent="claude" version="24.0.0" type="device">
  <diagram name="LoRaWAN FSM v3" id="fsm-diagram-v3">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="OFF" value="OFF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="100" height="50" as="geometry" /></mxCell>
        <mxCell id="RESET" value="RESET" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="180" y="40" width="100" height="50" as="geometry" /></mxCell>
        <mxCell id="BOOT" value="BOOT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="320" y="40" width="100" height="50" as="geometry" /></mxCell>
        <mxCell id="CHECKAT" value="CHECK_AT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="460" y="40" width="100" height="50" as="geometry" /></mxCell>
        <mxCell id="CONFIG" value="CONFIG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="600" y="40" width="100" height="50" as="geometry" /></mxCell>

        <mxCell id="READY" value="READY&#10;(configured, awaiting join())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="600" y="140" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="JOINING" value="JOINING&#10;(OTAA only, AT+JOIN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="600" y="250" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="JOINED" value="JOINED&#10;steady state -- TX/sleep/reset all orbit here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="360" width="260" height="70" as="geometry" /></mxCell>

        <mxCell id="TXPENDING" value="TX_PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="900" y="330" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="WAITTX" value="WAIT_TX_RESULT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="900" y="410" width="140" height="50" as="geometry" /></mxCell>

        <mxCell id="SLEEP" value="SLEEP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="300" y="370" width="120" height="50" as="geometry" /></mxCell>

        <mxCell id="ERROR" value="ERROR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="300" y="530" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="RECOVERING" value="RECOVERING&#10;retry -&gt; reset -&gt; reconfigure -&gt; rejoin(OTAA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="520" y="530" width="240" height="60" as="geometry" /></mxCell>

        <!-- boot chain -->
        <mxCell id="e1" value="power_on" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="OFF" target="RESET"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="reset done (GPIO or AT+RESET)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="RESET" target="BOOT"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="settle timer" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="BOOT" target="CHECKAT"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="AT_OK" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="CHECKAT" target="CONFIG"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="CONFIG_OK" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="CONFIG" target="READY"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- join chain -->
        <mxCell id="e6" value="JOIN_REQUEST + join_type==OTAA" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="READY" target="JOINING"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6b" value="JOIN_REQUEST + join_type==ABP&#10;(no AT command issued)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;exitX=0.15;exitY=1;entryX=0.1;entryY=0;" edge="1" parent="1" source="READY" target="JOINED"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="JOIN_SUCCESS" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="JOINING" target="JOINED"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="JOIN_FAILED / timeout" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;dashed=1;exitX=0.9;exitY=1;entryX=0.95;entryY=0;" edge="1" parent="1" source="JOINING" target="RECOVERING"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- tx orbit -->
        <mxCell id="e9" value="TX_REQUEST" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="JOINED" target="TXPENDING"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="cmd accepted" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="TXPENDING" target="WAITTX"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="TX_SUCCESS / TX_FAILED" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;exitX=0.1;exitY=1;entryX=1;entryY=0.3;" edge="1" parent="1" source="WAITTX" target="JOINED"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- sleep orbit -->
        <mxCell id="e12" value="sleep request" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="JOINED" target="SLEEP"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="wakeup" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="SLEEP" target="JOINED"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- leave -->
        <mxCell id="e14" value="leave()&#10;(local state clear only,&#10;no protocol-level deregistration)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;exitX=0.3;exitY=0;entryX=0.4;entryY=1;" edge="1" parent="1" source="JOINED" target="READY"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- link loss heuristic -->
        <mxCell id="e15" value="LINK_LOSS_SUSPECTED&#10;(host heuristic only -- N consecutive&#10;NO_ACK or LinkCheckReq margin below&#10;threshold. NOT modem-reported.&#10;Gated by CONFIG_LORA_E5_LINK_LOSS_DETECT,&#10;default OFF)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=9;dashed=1;fontColor=#b85450;" edge="1" parent="1" source="JOINED" target="RECOVERING"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- error / recovery -->
        <mxCell id="e16" value="AT_ERROR(structural) / TIMEOUT / UART_ERROR" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;dashed=1;" edge="1" parent="1" source="CHECKAT" target="ERROR"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" value="RECOVER" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="ERROR" target="RECOVERING"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" value="RESET" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="RECOVERING" target="RESET"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e19" value="ladder exhausted" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=10;dashed=1;" edge="1" parent="1" source="RECOVERING" target="ERROR"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note1" value="JOINED is the sole steady state (per review):&#10;TX, sleep, reset, leave, and (optional) link-loss&#10;detection are all transitions OUT of and back INTO&#10;JOINED, never through READY." style="text;html=1;align=left;fontSize=11;fontColor=#3c8a5e;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="Open item: does CONFIG auto-advance to&#10;JOINING for OTAA, or stop at READY awaiting&#10;an explicit join() call (as drawn)? Confirm." style="text;html=1;align=left;fontSize=11;fontColor=#0e8088;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="240" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
