/*
 * Enables &uart2 on esp32s3_devkitc/esp32s3/procpu for the LoRa-E5-HF,
 * wired to TX=GPIO40/RX=GPIO39 (this overlay's own uart2_default entry
 * below -- esp32s3_devkitc-pinctrl.dtsi only ships a uart1_default,
 * not a uart2 one, so it's defined here). Switched from &uart1
 * (GPIO17/18) to &uart2 (GPIO39/40) during hardware bring-up.
 *
 * current-speed matches the LoRa-E5's fixed default UART framing
 * (9600 8N1), already validated live against the real module.
 *
 * No `dmas`/`dma-names`/`&dma` here: lora_e5_uart.c uses the plain
 * Interrupt-Driven UART API (CONFIG_UART_INTERRUPT_DRIVEN), not the
 * DMA-backed Async API -- see lora_e5_uart.c's file doc comment and
 * docs/VERIFICATION_NEEDED.md for why that switch was made (an
 * intermittent Zephyr/ESP32 GDMA+timer-interaction issue found during
 * bring-up, not present with a plain interrupt+FIFO driver -- also
 * independently confirmed by a bare, non-DMA ESP-IDF/Arduino
 * passthrough sketch on these same pins working reliably).
 */

&uart2 {
	status = "okay";
	current-speed = <9600>;
	pinctrl-0 = <&uart2_default>;
	pinctrl-names = "default";
};

&pinctrl {
	i2c0_default: i2c0_default {
		group1 {
			pinmux = <I2C0_SDA_GPIO8>,
				 <I2C0_SCL_GPIO9>;
			bias-pull-up;
			drive-open-drain;
			output-high;
		};
	};

	uart2_default: uart2_default {
		group1 {
			pinmux = <UART2_TX_GPIO40>;
			output-high;
		};

		group2 {
			pinmux = <UART2_RX_GPIO39>;
			bias-pull-up;
		};
	};
};
