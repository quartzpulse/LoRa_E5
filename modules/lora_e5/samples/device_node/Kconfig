mainmenu "LoRa-E5 device_node sample"

config DEVICE_NODE_WAKEUP_TIME_SEC
	int "Deep sleep interval between wake/join/send cycles (seconds)"
	default 60
	help
	  Each wake reboots into main(), runs the init/config/join/send
	  sequence (lora_e5_resume_sync(), see docs/Device_State_Machine.md's
	  "Architecture" section), then re-arms an RTC timer for this many
	  seconds and powers off again.

